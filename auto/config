#!/bin/sh
set -e

HELP="$(lb config --help 2>/dev/null || true)"
BOOT_ARGS=""
if printf '%s' "$HELP" | grep -q -- '--bootloaders'; then
  BOOT_ARGS="--bootloaders syslinux,grub-efi"
elif printf '%s' "$HELP" | grep -q -- '--bootloader'; then
  BOOT_ARGS="--bootloader syslinux"
fi

lb config \
  --mode debian \
  --architectures amd64 \
  --distribution bookworm \
  --binary-images iso-hybrid \
  --debian-installer live \
  $BOOT_ARGS \
  --archive-areas "main contrib non-free non-free-firmware" \
  --bootappend-live "boot=live components username=puenteos hostname=puenteos" \
  --iso-application "PuenteOS" \
  --iso-publisher "PuenteOS" \
  --iso-preparer "PuenteOS build" \
  --iso-volume "PuenteOS_1.0"
